@article{10.2307/23539528,
 ISSN = {01624962, 15291456},
 URL = {http://www.jstor.org/stable/23539528},
 abstract = {Artie Shaw's career as clarinetist-band leader, then writer, exemplifies the passage of certain professionals in the arts toward intellectualism. Having risen from poverty to attain the height of fame in popular music he found himself dissatisfied—dissatisfied with the demands of lay listeners, often unfamiliar with his subtleties, and with the cramping nature of music itself. Since 1950 he has tried to become a writer and intellectual. His success at the latter endeavor is not easy to evaluate as yet.},
 author = {Barnett Singer},
 journal = {Biography},
 number = {4},
 pages = {326--339},
 publisher = {University of Hawai'i Press},
 title = {Becoming an Intellectual: The Strange Saga of Artie Shaw},
 volume = {4},
 year = {1981}
}

